  t_IgG  <- all_trajectories_list[[i]]$IgG   %>% rename(IgG = Trajectory)
  t_nAb  <- all_trajectories_list[[i]]$nAb   %>% rename(nAb = Trajectory)
  t_MBC  <- all_trajectories_list[[i]]$MBC   %>% rename(MBC = Trajectory)
  t_IFNg <- all_trajectories_list[[i]]$Tcell %>% rename(IFNg = Trajectory)
  
  merged_traj <- t_IgG %>%
    left_join(t_nAb,  by = c("Virtual_id", "Real_ID", "Days")) %>%
    left_join(t_MBC,  by = c("Virtual_id", "Real_ID", "Days")) %>%
    left_join(t_IFNg, by = c("Virtual_id", "Real_ID", "Days")) %>%
    mutate(
      log_IgG  = log10(IgG),
      log_nAb  = log10(nAb),
      log_MBC  = log10(MBC),
      log_IFNg = log10(IFNg)
    )
  
  # Slice to window
  merged_traj_window <- merged_traj %>% filter(Days >= head_day & Days <= tail_day)
  
  # B. ASSIGN STATIC INFO
  virtual_cohort <- merged_traj %>%
    dplyr::select(Virtual_id, Real_ID) %>%
    distinct() %>%
    left_join(master_new_inf, by = "Real_ID")
  
  # C. TMERGE & SCALING
 df_base <- tmerge(virtual_cohort, virtual_cohort, id = Virtual_id, 
                    endpt = event(new_max_t, new_inf))
  
  df_processed <- tmerge(df_base, merged_traj_window, id = Virtual_id,
                         log_IgG  = tdc(Days, log_IgG),
                         log_nAb  = tdc(Days, log_nAb),
                         log_MBC  = tdc(Days, log_MBC),
                         log_IFNg = tdc(Days, log_IFNg)) %>% 
    na.omit() %>%
    mutate(
      scale_IgG  = scale(log_IgG),
      scale_nAb  = scale(log_nAb),
      scale_MBC  = scale(log_MBC),
      scale_IFNg = scale(log_IFNg)
    )
  
  # Exclude the hybrid immune children from the survival dataset
 # df_processed <- df_processed %>% filter(!Real_ID %in% inf_b4_n$Real_ID)
  
  # D1. UNIVARIATE MODELS
  fit_uni_IgG  <- tryCatch({ coxph(Surv(tstart, tstop, endpt) ~ scale_IgG  + cluster(Virtual_id), data = df_processed) }, error = function(e) NULL)
  fit_uni_nAb  <- tryCatch({ coxph(Surv(tstart, tstop, endpt) ~ scale_nAb  + cluster(Virtual_id), data = df_processed) }, error = function(e) NULL)
  fit_uni_MBC  <- tryCatch({ coxph(Surv(tstart, tstop, endpt) ~ scale_MBC  + cluster(Virtual_id), data = df_processed) }, error = function(e) NULL)
  fit_uni_IFNg <- tryCatch({ coxph(Surv(tstart, tstop, endpt) ~ scale_IFNg + cluster(Virtual_id), data = df_processed) }, error = function(e) NULL)
  
  if(!is.null(fit_uni_IgG))  survival_results$Uni_HR_IgG[i]  <- exp(coef(fit_uni_IgG)["scale_IgG"])
  if(!is.null(fit_uni_nAb))  survival_results$Uni_HR_nAb[i]  <- exp(coef(fit_uni_nAb)["scale_nAb"])
  if(!is.null(fit_uni_MBC))  survival_results$Uni_HR_MBC[i]  <- exp(coef(fit_uni_MBC)["scale_MBC"])
  if(!is.null(fit_uni_IFNg)) survival_results$Uni_HR_IFNg[i] <- exp(coef(fit_uni_IFNg)["scale_IFNg"])

  # D2. MULTIVARIATE MODEL (No IgG)
  fit_multi <- tryCatch({
    coxph(Surv(tstart, tstop, endpt) ~ scale_nAb + scale_MBC + scale_IFNg + cluster(Virtual_id), data = df_processed)
  }, error = function(e) { NULL })
  
  if(!is.null(fit_multi)) {
    survival_results$Multi_HR_nAb[i]  <- exp(coef(fit_multi)["scale_nAb"])
    survival_results$Multi_HR_MBC[i]  <- exp(coef(fit_multi)["scale_MBC"])
    survival_results$Multi_HR_IFNg[i] <- exp(coef(fit_multi)["scale_IFNg"])
  }
}

