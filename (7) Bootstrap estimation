```{r}
all_ebes_list     <- list() # Stores all parameters from Monolix
all_mappings_list <- list() # Stores the ID mapping

for(i in 1:B) {
  cat("\n=== GENERATING BOOTSTRAP", i, "===\n")
  
  # 1. Resample and save the exact ID mapping 
  boot_ids <- sample(master_IDs, size = N, replace = TRUE)
  all_mappings_list[[i]] <- data.frame(id = as.character(1:N), ID = boot_ids)
  
  # 2. Construct the 4 temporary datasets
  boot_df_IgG <- data.frame(); boot_df_nAb <- data.frame(); boot_df_MBC <- data.frame(); boot_df_Tcell <- data.frame()
  for(new_id in 1:length(boot_ids)) {
    target <- boot_ids[new_id]
    
    tmp_IgG <- df_IgG[df_IgG$ID == target, ]; if(nrow(tmp_IgG)>0){tmp_IgG$ID <- new_id; boot_df_IgG <- rbind(boot_df_IgG, tmp_IgG)}
    tmp_nAb <- df_nAb[df_nAb$ID == target, ]; if(nrow(tmp_nAb)>0){tmp_nAb$ID <- new_id; boot_df_nAb <- rbind(boot_df_nAb, tmp_nAb)}
    tmp_MBC <- df_MBC[df_MBC$ID == target, ]; if(nrow(tmp_MBC)>0){tmp_MBC$ID <- new_id; boot_df_MBC <- rbind(boot_df_MBC, tmp_MBC)}
    tmp_Tcell <- df_Tcell[df_Tcell$ID == target, ]; if(nrow(tmp_Tcell)>0){tmp_Tcell$ID <- new_id; boot_df_Tcell <- rbind(boot_df_Tcell, tmp_Tcell)}
  }
  
  f_IgG <- paste0("temp_IgG_", i, ".csv"); f_nAb <- paste0("temp_nAb_", i, ".csv")
  f_MBC <- paste0("temp_MBC_", i, ".csv"); f_Tcell <- paste0("temp_Tcell_", i, ".csv")
  write.csv(boot_df_IgG, f_IgG, row.names=F, na=".", quote=F); write.csv(boot_df_nAb, f_nAb, row.names=F, na=".", quote=F)
  write.csv(boot_df_MBC, f_MBC, row.names=F, na=".", quote=F); write.csv(boot_df_Tcell, f_Tcell, row.names=F, na=".", quote=F)
  
  # 3. Run Monolix with disposable projects
  cat("  -> Running Monolix Models...\n")
  files <- c("4k_r19.mlxtran", "4k_r22_symp.mlxtran", "full_71_r34_4.mlxtran", "r12.mlxtran") # specific runs used
  temps <- c(f_IgG, f_nAb, f_MBC, f_Tcell)
  names <- c("IgG", "nAb", "MBC", "Tcell")
  iter_params <- list() 
  success <- TRUE

  for(m in 1:4) {
    tryCatch({
      disposable_proj <- paste0("temp_run_", names[m], ".mlxtran")
      file.copy(from = files[m], to = disposable_proj, overwrite = TRUE)
      Sys.sleep(0.2) 
      loadProject(disposable_proj)
      setData(dataFile = temps[m], headerTypes = getData()$headerTypes)
      runPopulationParameterEstimation()
      runConditionalModeEstimation()
      Sys.sleep(0.5)
      
      raw_ebes <- getEstimatedIndividualParameters()$conditionalMode
      iter_params[[names[m]]] <- left_join(raw_ebes, all_mappings_list[[i]], by = "id")
      
    }, error = function(e) { 
      cat("      [!] CRASH DETECTED on", names[m], "->", conditionMessage(e), "\n")
      success <<- FALSE 
    })
    
    if(!success) {
      break
    }
  }
  
  # 4. Save to master storage
  if(success) {
    all_ebes_list[[i]] <- iter_params
    cat("  -> [SUCCESS] Parameters stored in memory.\n")
  } else {
    all_ebes_list[[i]] <- NA 
    cat("  -> [FAILED] Monolix convergence issue. Skipping to next bootstrap...\n")
  }
  
  # 5. Clean up temporary CSVs and disposable Monolix files
  file.remove(temps)
  suppressWarnings(file.remove(paste0("temp_run_", names, ".mlxtran")))
}
cat("\n=== DATA GENERATION COMPLETE ===\n")
