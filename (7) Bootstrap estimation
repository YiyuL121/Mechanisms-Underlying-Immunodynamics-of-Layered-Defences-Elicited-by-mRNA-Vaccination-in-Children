##################### Calculate the final CI and HRs
```{r}
final_ci_table <- survival_results %>%
  # Drop the Iteration column so we only analyze the HRs
  dplyr::select(-Iteration) %>%
  pivot_longer(cols = everything(), names_to = "Model_and_Biomarker", values_to = "HR") %>%
  filter(!is.na(HR)) %>%
  group_by(Model_and_Biomarker) %>%
  summarise(
    Median_HR  = quantile(HR, probs = 0.500),
    Lower_95CI = quantile(HR, probs = 0.025),
    Upper_95CI = quantile(HR, probs = 0.975),
    Valid_Bootstraps = n() # Counts how many iterations successfully converged
  ) %>%
  mutate(
    Publication_Format = sprintf("%.2f (%.2f, %.2f)", Median_HR, Lower_95CI, Upper_95CI)
  )
print(final_ci_table)
