library(deSolve)
library(dplyr)
library(purrr)

Tmin <- 0
Tmax <- 450 
step_size <- 1
times <- c(seq(Tmin, Tmax, step_size))

ode_ab_ind <- function(pars, immunity) { 
  
  # Safe extraction using names
  k1 <- as.numeric(pars["k1"]) 
  k2 <- as.numeric(pars["k2"]) 
  k3 <- as.numeric(pars["k3"]) 
  k4 <- as.numeric(pars["k4"]) 
  A0 <- as.numeric(pars["A0"]) 
  tau <- as.numeric(pars["tau"])  
  
  # Safe extraction using column names from your immunity df
  t_inf <- as.numeric(immunity$t_inf)
  t_boost <- as.numeric(immunity$t_boost)
  t_inf_2 <- as.numeric(immunity$t_inf_2)
  immu <- as.numeric(immunity$immu)
  
  adjusted <- min(t_inf+tau, t_boost) 
  
  infection <- data.frame(times = times, VV = rep(0, length(times)), VVI = rep(0, length(times)),VVV = rep(0, length(times)), 
                          VVIV = rep(0, length(times)),VVIVI = rep(0, length(times)),VVII = rep(0, length(times)))
  
  infection <- infection %>% mutate(
    VV = case_when(times <= tau ~ k1, times > tau ~ -k2),
    VVI = case_when(times <= tau ~ k1, times > tau & times <= t_inf ~ -k2, times > t_inf & times <= t_inf+tau ~ k3, times > t_inf+tau ~ -k4),
    VVV = case_when(times <= tau ~ k1, times > tau & times <= t_boost ~ -k2, times > t_boost & times <= t_boost+tau ~ k3, times > t_boost+tau ~ -k4),
    VVIV = case_when(times <= tau ~ k1, times > tau & times <= t_inf ~ -k2, times > t_inf & times <= adjusted ~ k3, times > adjusted & times <= t_boost ~ -k4, times > t_boost & times <= t_boost+tau ~ k3, times > t_boost+tau ~ -k4),
    VVIVI = case_when(times <= tau ~ k1, times > tau & times <= t_inf ~ -k2, times > t_inf & times <= adjusted ~ k3, times > adjusted & times <= t_boost ~ -k4, times > t_boost & times <= t_boost+tau ~ k3, times > t_boost+tau & times <= t_inf_2 ~ -k4, times > t_inf_2 & times <= t_inf_2+tau ~ k3, times > t_inf_2+tau  ~ -k4),
    VVII = case_when(times <= tau ~ k1, times > tau & times <= t_inf ~ -k2, times > t_inf & times <= t_inf+tau ~ k3, times > t_inf+tau & times <= t_inf_2 ~ -k4, times > t_inf_2 & times <= t_inf_2+tau ~ k3, times > t_inf_2+tau  ~ -k4)
  )
  
  k_t <- approxfun(infection$times, infection[,immu+1], rule = 2) 
  
  derivs<-function(times,y,pars,k_t){
    with(as.list(c(pars,y)),{
      k <- k_t(times)   
      dA <- k*A
      return(list(c(dA)))
    })
  }
  
  y <- c(A=A0)
  out <- ode(y=y, parms=pars, times=times, func=derivs, k_t=k_t)
  return(as.data.frame(out))
}

calc_iteration_trajectories <- function(ebe_df, immunity_master) {
  # ebe_df is the dataframe for ONE biomarker for ONE bootstrap iteration
  Fit <- list()
  for(i in 1:nrow(ebe_df)){
    # 1. Grab parameters for this virtual kid
    pars <- c(k1 = ebe_df$k1[i],
              k2 = ebe_df$k2[i],
              k3 = ebe_df$k3[i],
              k4 = ebe_df$k4[i],
              A0 = ebe_df$A0[i],
              tau = ebe_df$tau[i])
    
    # 2. Get the REAL ID and pull their specific immunity history
    real_id <- ebe_df$ID[i]
    immu_i <- immunity_master[immunity_master$ID == real_id, ]
    
    # 3. Calculate ODE
    fitted <- ode_ab_ind(pars, immu_i)
    
    # 4. Save the trajectory with the virtual 'id' and real 'ID' attached
    Fit[[i]] <- data.frame(
      Virtual_id = ebe_df$id[i], 
      Real_ID = real_id,
      Days = times,
      Trajectory = fitted$A
    )
  }
  # Combine all 70 children into one clean dataframe
  return(bind_rows(Fit))
}
